graph TB
    subgraph PBS["🗂️ Planning & Resource Mgmt (PBS)"]
        PBS_agg["Project · Activity · Component\nAssignment · Baseline · WOR\nTaskReadiness · KPI · Prediction"]
    end

    subgraph WF["👥 Workforce & Organization (HR)"]
        WF_agg["Person · Organisation · Discipline\nTeam · Schedule · Location(?)"]
    end

    subgraph TS["⏰ Timekeeping & Hours"]
        TS_agg["TimeSheet · ErpHourline · Hourline\nBalance · BalancePolicy\nCorrectionTimesheet · HourType"]
    end

    subgraph DEV["📱 Devices & Clocking"]
        DEV_agg["ClockingTerminal · ShopFloorTerminal\nAccessControlTime · ClockingTerminalPunch\nPersonalDailyClockTimes"]
    end

    subgraph TKT["🎫 Workflow & Ticketing"]
        TKT_agg["Ticket · TransportRequest\nStopWorkOrder · TicketRemark\n(Elsa state machine)"]
    end

    subgraph SYN["🔄 Sync & Import Pipeline"]
        SYN_agg["SyncLog · ImportConfig\nHangfire jobs · Connectors\n(XER · Sciforma · ERP · EntryTime)"]
    end

    subgraph SYS["⚙️ System Admin & Infrastructure"]
        SYS_agg["AppSetting · License · SystemAction\nUser · Role · PageSetting\nProcessors (35+) · Cache"]
    end

    %% Planning ↔ Workforce
    PBS -->|"FK read: Person, Organisation\n(Assignment, Project)"| WF

    %% Planning ↔ Timekeeping
    PBS <-->|"⚠️ Shared bridge table\nTimeSheetWeeklyHourline\n(FK: Activity + TimeSheet)"| TS

    %% Timekeeping → Workforce
    TS -->|"FK read: Person, PersonSchedule\napproval chain + balance policy"| WF

    %% Devices → Workforce
    DEV -->|"FK read: Person, PersonSchedule\n(punch matching)"| WF

    %% Devices → Timekeeping
    DEV -->|"PersonalDailyClockTimes\n(feeds hourline calcs)"| TS

    %% Workflow → Planning
    TKT -->|"FK read: Activity, Component, Project\n(ActivityTicketRelation)\n[NEEDS REVIEW: mutation dir]"| PBS

    %% Workflow → Workforce
    TKT -->|"FK read: Person, Organisation\n(reporter, assignee)"| WF

    %% Workflow self (Elsa events)
    TKT -->|"Domain events\nTicketStateChange\nTransportRequestCreated\nStopWorkOrderCreated"| TKT

    %% Sync → all contexts (writes)
    SYN -->|"ImportJobs: Project, Activity\nComponent, Assignment\nTaskReadiness, Material"| PBS
    SYN -->|"ImportJobs: Person\nOrganisation, Discipline"| WF
    SYN -->|"ImportJobs: TimeSheet\nHourline, HourType"| TS
    SYN -->|"ImportJob: AccessControl\npunch records"| DEV
    SYN -->|"SyncFinishEvent"| TKT

    %% System → all (cache + processors)
    SYS -->|"⚠️ Processors + cache flush\n(implicit orchestration)"| PBS
    SYS -->|"Processors + cache flush"| TS
    SYS -->|"Processors + cache flush"| WF
    SYS -->|"Hangfire job scheduling"| SYN
    SYS -->|"Elsa engine lifecycle"| TKT
    SYS -.->|"AppSetting lookup\n(all contexts)"| PBS
    SYS -.->|"AppSetting lookup"| TS
    SYS -.->|"AppSetting lookup"| WF

    %% Styling
    style PBS fill:#dbeafe,stroke:#3b82f6
    style WF  fill:#f3e8ff,stroke:#9333ea
    style TS  fill:#fef9c3,stroke:#ca8a04
    style DEV fill:#dcfce7,stroke:#16a34a
    style TKT fill:#fce7f3,stroke:#db2777
    style SYN fill:#ecfdf5,stroke:#059669
    style SYS fill:#ede9fe,stroke:#7c3aed
