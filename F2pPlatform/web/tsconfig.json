{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist/out-tsc",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "paths": {
      "@f2p/shared/api-core": ["libs/shared/api-core/src/index.ts"],
      "@f2p/shared/platform-events": ["libs/shared/platform-events/src/index.ts"],
      "@f2p/shared/ui": ["libs/shared/ui/src/index.ts"],
      "@f2p/identity/data-access": ["libs/identity/data-access/src/index.ts"],
      "@f2p/reference/data-access": ["libs/reference/data-access/src/index.ts"],
      "@f2p/reference/feature-status": ["libs/reference/feature-status/src/index.ts"],
      "@f2p/hour-approvals/data-access": ["libs/hour-approvals/data-access/src/index.ts"],
      "@f2p/hour-approvals/feature-tasks": ["libs/hour-approvals/feature-tasks/src/index.ts"],
      "@f2p/control-plane/data-access": ["libs/control-plane/data-access/src/index.ts"],
      "@f2p/control-plane/feature-tenants": ["libs/control-plane/feature-tenants/src/index.ts"],
      "@f2p/platform-events/feature-live": ["libs/platform-events/feature-live/src/index.ts"]
    }
  }
}
