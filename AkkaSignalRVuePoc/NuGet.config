<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Machine-wide NuGet.config uses packageSourceMapping with an explicit allow-list.
    This POC adds a catch-all pattern so any public package can restore from nuget.org.
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
