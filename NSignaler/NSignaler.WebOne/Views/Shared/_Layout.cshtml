<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @Styles.Render("~/Content/bootstrap")
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/jquerysignalR")
    @Scripts.Render("~/bundles/bootstrap") 
    <script src="@Url.Content("~/Scripts/Highcharts-3.0.1/js/highcharts.src.js")" type="text/javascript"></script>
   <script src="@Url.Content("~/Scripts/Highcharts-3.0.1/js/highcharts-more.js")" type="text/javascript"></script>
   <script src="@Url.Content("~/Scripts/Highcharts-3.0.1/js/modules/funnel.js")" type="text/javascript"></script>
    <script src="~/signalr/hubs"></script>
</head>
<body>
    @RenderBody()

    
    @RenderSection("scripts", required: false)
    <script type="text/javascript">
        $(document).ready(function () {
            nSignalR.EventHub.init(
                '@HttpContext.Current.Session.SessionID');
            nSignalR.SignalRStarter.start();
        });
    </script>
</body>
</html>