<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Platform.Serilog.Logging.Testing</RootNamespace>
    <AssemblyName>Platform.Serilog.Logging.Testing</AssemblyName>
    <Description>Serilog test helpers: shared ConfigureShared pipeline + xUnit3 test output sink.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Serilog.Extensions.Logging" />
    <PackageReference Include="Serilog.Sinks.XUnit3" />
    <PackageReference Include="Platform.Serilog.Logging" Condition="'$(IsPackable)' == 'true'" />
    <ProjectReference Include="..\Platform.Serilog.Logging\Platform.Serilog.Logging.csproj" Condition="'$(IsPackable)' != 'true'" />
  </ItemGroup>

</Project>
